ut/competitions/playground-series-s6e3/train.csv\"\nTEST_PATH = \"/kaggle/input/competitions/playground-series-s6e3/test.csv\"\nSUB_PATH = \"/kaggle/input/competitions/playground-series-s6e3/sample_submission.csv\"\n\ntrain = pd.read_csv(TRAIN_PATH)\ntest = pd.read_csv(TEST_PATH)\nsub = pd.read_csv(SUB_PATH)\n\nprint(f\"Train shape: {train.shape}\")\nprint(f\"Test shape:  {test.shape}\")\nprint(f\"Submission shape: {sub.shape}\")\nprint(f\"\\nTarget distribution:\\n{train['Churn'].value_counts(normalize=True)}\")","metadata":{"_uuid":"c362722b-b767-4ae9-aa9d-0caf68ed0fe4","_cell_guid":"2b12f854-1565-4ff1-ad9d-977fbb0ed5ff","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-03-01T08:12:32.598581Z","iopub.execute_input":"2026-03-01T08:12:32.598974Z","iopub.status.idle":"2026-03-01T08:12:35.744561Z","shell.execute_reply.started":"2026-03-01T08:12:32.598925Z","shell.execute_reply":"2026-03-01T08:12:35.743277Z"}},"outputs":[{"name":"stdout","text":"Train shape: (594194, 21)\nTest shape:  (254655, 20)\nSubmission shape: (254655, 2)\n\nTarget distribution:\nChurn\nNo     0.774792\nYes    0.225208\nName: proportion, dtype: float64\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"# === Cell 3: Data Overview ===\nprint(\"=== Column Types ===\")\nprint(train.dtypes)\nprint(f\"\\n=== Missing Values ===\")\nprint(train.isnull().sum()[train.isnull().sum() > 0])\nif train.isnull().sum().sum() == 0:\n    print(\"No missing values in train.\")\nprint(f\"\\n=== Unique Values Per Column ===\")\nfor col in train.columns:\n    print(f\"  {col}: {train[col].nunique()}\")","metadata":{"_uuid":"796a0740-d1ce-4001-94eb-4878f869579d","_cell_guid":"5b25627e-deb8-483b-9833-a5486012f79b","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-03-01T08:12:35.746572Z","iopub.execute_input":"2026-03-01T08:12:35.747766Z","iopub.status.idle":"2026-03-01T08:12:37.798540Z","shell.execute_reply.started":"2026-03-01T08:12:35.747730Z","shell.execute_reply":"2026-03-01T08:12:37.797253Z"}},"outputs":[{"name":"stdout","text":"=== Column Types ===\nid                    int64\ngender               object\nSeniorCitizen         int64\nPartner              object\nDependents           object\ntenure                int64\nPhoneService         object\nMultipleLines        object\nInternetService      object\nOnlineSecurity       object\nOnlineBackup         object\nDeviceProtection     object\nTechSupport          object\nStreamingTV          object\nStreamingMovies      object\nContract             object\nPaperlessBilling     object\nPaymentMethod        object\nMonthlyCharges      float64\nTotalCharges        float64\nChurn                object\ndtype: object\n\n=== Missing Values ===\nSeries([], dtype: int64)\nNo missing values in train.\n\n=== Unique Values Per Column ===\n  id: 594194\n  gender: 2\n  SeniorCitizen: 2\n  Partner: 2\n  Dependents: 2\n  tenure: 72\n  PhoneService: 2\n  MultipleLines: 3\n  InternetService: 3\n  OnlineSecurity: 3\n  OnlineBackup: 3\n  DeviceProtection: 3\n  TechSupport: 3\n  StreamingTV: 3\n  StreamingMovies: 3\n  Contract: 3\n  PaperlessBilling: 2\n  PaymentMethod: 4\n  MonthlyCharges: 1921\n  TotalCharges: 31910\n  Churn: 2\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"# === Cell 4: Feature Engineering & Target Encoding ===\n# Encode target: \"Yes\" -> 1, \"No\" -> 0\ntarget_col = \"Churn\"\nid_col = \"id\"\n\n# Encode target\ntrain[\"target\"] = (train[target_col] == \"Yes\").astype(int)\nprint(f\"Encoded target distribution:\\n{train['target'].value_counts()}\")\n\n# Identify feature columns\ndrop_cols = [id_col, target_col, \"target\"]\nfeature_cols = [c for c in train.columns if c not in drop_cols]\n\n# Separate numeric and categorical\nnum_cols = [c for c in feature_cols if train[c].dtype in ['int64', 'float64']]\ncat_cols = [c for c in feature_cols if train[c].dtype == 'object']\n\nprint(f\"\\nNumeric features ({len(num_cols)}): {num_cols}\")\nprint(f\"Categorical features ({len(cat_cols)}): {cat_cols}\")","metadata":{"_uuid":"1c4e05c4-06e8-4689-a1c9-ab9f2da73fb3","_cell_guid":"152b0585-0a3e-411f-945f-6caef9ee182e","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-03-01T08:12:37.799990Z","iopub.execute_input":"2026-03-01T08:12:37.800263Z","iopub.status.idle":"2026-03-01T08:12:37.867529Z","shell.execute_reply.started":"2026-03-01T08:12:37.800240Z","shell.execute_reply":"2026-03-01T08:12:37.865929Z"}},"outputs":[{"name":"stdout","text":"Encoded target distribution:\ntarget\n0    460377\n1    133817\nName: count, dtype: int64\n\nNumeric features (4): ['SeniorCitizen', 'tenure', 'MonthlyCharges', 'TotalCharges']\nCategorical features (15): ['gender', 'Partner', 'Dependents', 'PhoneService', 'MultipleLines', 'InternetService', 'OnlineSecurity', 'OnlineBackup', 'DeviceProtection', 'TechSupport', 'StreamingTV', 'StreamingMovies', 'Contract', 'PaperlessBilling', 'PaymentMethod']\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"# === Cell 5: Build Leakage-Safe Pipeline ===\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.compose import ColumnTransformer\nfrom sklearn.preprocessing import OrdinalEncoder\nimport lightgbm as lgb\n\n# Preprocessor: encode categoricals, pass through numerics\npreprocessor = ColumnTransformer(\n    transformers=[\n        (\"num\", \"passthrough\", num_cols),\n        (\"cat\", OrdinalEncoder(handle_unknown=\"use_encoded_value\", unknown_value=-1), cat_cols),\n    ]\n)\n\n# LightGBM with sensible defaults for this dataset\nlgb_params = {\n    \"n_estimators\": 1000,\n    \"learning_rate\": 0.05,\n    \"max_depth\": 6,\n    \"num_leaves\": 31,\n    \"subsample\": 0.8,\n    \"colsample_bytree\": 0.8,\n    \"reg_alpha\": 0.1,\n    \"reg_lambda\": 0.1,\n    \"min_child_samples\": 50,\n    \"random_state\": 42,\n    \"n_jobs\": -1,\n    \"verbosity\": -1,\n}\n\npipeline = Pipeline([\n    (\"preprocessor\", preprocessor),\n    (\"classifier\", lgb.LGBMClassifier(**lgb_params)),\n])\n\nprint(\"Pipeline built successfully.\")\nprint(f\"Pipeline steps: {[name for name, _ in pipeline.steps]}\")","metadata":{"_uuid":"b544e2df-6ee1-4036-9dc1-26c7677418d5","_cell_guid":"c801d99c-846a-4ceb-b358-b57b430dd48f","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-03-01T08:12:37.868986Z","iopub.execute_input":"2026-03-01T08:12:37.869374Z","iopub.status.idle":"2026-03-01T08:12:42.766335Z","shell.execute_reply.started":"2026-03-01T08:12:37.869320Z","shell.execute_reply":"2026-03-01T08:12:42.765094Z"}},"outputs":[{"name":"stdout","text":"Pipeline built successfully.\nPipeline steps: ['preprocessor', 'classifier']\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# === Cell 6: Stratified K-Fold Cross-Validation with OOF Tracking ===\nfrom sklearn.model_selection import StratifiedKFold\nfrom sklearn.metrics import roc_auc_score\n\nN_FOLDS = 5\nSEED = 42\n\nX = train[feature_cols]\ny = train[\"target\"]\nX_test = test[feature_cols]\n\nskf = StratifiedKFold(n_splits=N_FOLDS, shuffle=True, random_state=SEED)\n\noof_preds = np.zeros(len(X))\ntest_preds = np.zeros(len(X_test))\nfold_scores = []\n\nprint(f\"Running {N_FOLDS}-fold Stratified CV...\\n\")\n\nfor fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n    X_train, X_val = X.iloc[train_idx], X.iloc[val_idx]\n    y_train, y_val = y.iloc[train_idx], y.iloc[val_idx]\n\n    # Clone pipeline for each fold (leakage-safe)\n    from sklearn.base import clone\n    fold_pipeline = clone(pipeline)\n\n    # Fit with early stopping via callbacks\n    fold_pipeline.fit(\n        X_train, y_train,\n        classifier__eval_set=[(preprocessor.fit_transform(X_val), y_val)],\n        classifier__callbacks=[lgb.early_stopping(100, verbose=False)],\n    )\n\n    # OOF predictions\n    oof_preds[val_idx] = fold_pipeline.predict_proba(X_val)[:, 1]\n\n    # Test predictions (averaged across folds)\n    test_preds += fold_pipeline.predict_proba(X_test)[:, 1] / N_FOLDS\n\n    fold_auc = roc_auc_score(y_val, oof_preds[val_idx])\n    fold_scores.append(fold_auc)\n    print(f\"  Fold {fold+1}: AUC = {fold_auc:.5f}\")\n\noverall_auc = roc_auc_score(y, oof_preds)\nprint(f\"\\n{'='*40}\")\nprint(f\"  OOF AUC:       {overall_auc:.5f}\")\nprint(f\"  Mean Fold AUC: {np.mean(fold_scores):.5f} ± {np.std(fold_scores):.5f}\")\nprint(f\"{'='*40}\")","metadata":{"_uuid":"1f6cda40-953c-403e-9098-ad657731ca58","_cell_guid":"c3c05f44-4bef-4e90-9454-904550c4181d","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false},"execution":{"iopub.status.busy":"2026-03-01T08:12:42.767684Z","iopub.execute_input":"2026-03-01T08:12:42.768424Z","iopub.status.idle":"2026-03-01T08:15:42.697285Z","shell.execute_reply.started":"2026-03-01T08:12:42.768364Z","shell.execute_reply":"2026-03-01T08:15:42.696099Z"}},"outputs":[{"name":"stdout","text":"Running 5-fold Stratified CV...\n\n  Fold 1: AUC = 0.91585\n  Fold 2: AUC = 0.91701\n  Fold 3: AUC = 0.91629\n  Fold 4: AUC = 0.91745\n  Fold 5: AUC = 0.91483\n\n========================================\n  OOF AUC:       0.91628\n  Mean Fold AUC: 0.91629 ± 0.00092\n========================================\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"# === Cell 7: Generate Submission ===\nsub[\"Churn\"] = test_preds\nsub.to_csv(\"submission.csv\", index=False)\n\nprint(f\"Submission shape: {sub.shape}\")\nprint(f\"Prediction range: [{sub['Churn'].min():.4f}, {sub['Churn'].max():.4f}]\")\nprint(f\"Prediction mean:  {sub['Churn'].mean():.4f}\")\nprint(f\"\\nFirst 10 rows:\")\nprint(sub.head(10))\nprint(\"\\nsubmission.csv saved successfully!\")","metadata":{"_uuid":"4daf4da1-643c-42d9-8f5d-07b4936db7b1","_cell_guid":"c8539d0a-c658-4432-bef2-70a5fe886d67","trusted":true,"collapsed":false,"jupyter